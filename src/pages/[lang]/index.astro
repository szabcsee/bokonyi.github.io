---
import Layout from '../../layouts/Layout.astro';
import { languages, defaultLang, getLangFromUrl } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: keyof typeof languages };
const t = (await import('../../i18n/ui')).ui[lang as Lang];
---

<Layout
  title={t['blog.title']}
  description={t['blog.description']}
  lang={lang}
>
  <div class="layout-grid-left" slot="left">
  </div>
  <div class="layout-grid-right" slot="right">
    <div class="hero-text">
      <h1 class="no-mt">Welcome to my blog</h1>
      <p>Stuff that I write about — AI, development, tools, and whatever else I'm thinking about.</p>
      <a href={`/${lang}/blog`} class="cta-link">Read the blog →</a>
    </div>
  </div>
</Layout>

<style>
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-text h1 {
    font-size: 2.5rem;
    line-height: 1.2;
  }

  .hero-text p {
    font-size: 1.125rem;
    color: #a0a0a0;
    max-width: 40ch;
  }

  .cta-link {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--primary);
    color: white;
    text-decoration: none;
    font-weight: 600;
    border-radius: 4px;
    width: fit-content;
    margin-top: 0.5rem;
  }

  .cta-link:hover {
    opacity: 0.9;
  }
</style>