---
import { defaultLang, languages } from '../i18n/ui';

const target = `/${defaultLang}/`;
const supported = Object.keys(languages);
---
<!DOCTYPE html>
<html lang={defaultLang}>
  <head>
    <meta charset="UTF-8" />
    <title>bokonyi.com</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    {supported.map((l) => (
      <link rel="alternate" hreflang={l} href={`/${l}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={target} />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>…</p>
    <script is:inline define:vars={{ supported, fallback: target }}>
      try {
        const pref = (navigator.languages && navigator.languages[0]) || navigator.language || '';
        const code = pref.toLowerCase().split('-')[0];
        const dest = supported.includes(code) ? `/${code}/` : fallback;
        window.location.replace(dest);
      } catch (_e) {
        window.location.replace(fallback);
      }
    </script>
  </body>
</html>
