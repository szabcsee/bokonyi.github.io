// Root page redirects to the default language version
// Language detection happens client-side for better UX

const defaultLang = 'en';
const referer = Astro.request.headers.get('referer') || '';
const acceptLang = Astro.request.headers.get('accept-language') || '';

// Simple redirect to default language
// The user's browser language could be parsed here for more sophisticated detection
return Astro.redirect(`/${defaultLang}`);
